def get_conn():
return sqlite3.connect(DB_PATH, check_same_thread=False)

def init_db():
conn = get_conn()
cur = conn.cursor()

```
cur.executescript("""
CREATE TABLE IF NOT EXISTS cocktails (
    id      INTEGER PRIMARY KEY AUTOINCREMENT,
    name    TEXT NOT NULL UNIQUE,
    price   REAL NOT NULL DEFAULT 0
);

CREATE TABLE IF NOT EXISTS zutaten (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    name            TEXT NOT NULL UNIQUE,
    einheit         TEXT NOT NULL DEFAULT 'ml',
    kosten_pro_einheit REAL NOT NULL DEFAULT 0
);

CREATE TABLE IF NOT EXISTS cocktail_zutaten (
    cocktail_id INTEGER REFERENCES cocktails(id) ON DELETE CASCADE,
    zutaten_id  INTEGER REFERENCES zutaten(id)  ON DELETE CASCADE,
    menge       REAL NOT NULL,
    PRIMARY KEY (cocktail_id, zutaten_id)
);

CREATE TABLE IF NOT EXISTS events (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    name            TEXT NOT NULL,
    datum           TEXT NOT NULL,
    abrechnung      TEXT NOT NULL,   -- 'pauschale' | 'pro_person' | 'kombi'
    pauschale       REAL DEFAULT 0,
    preis_pro_kopf  REAL DEFAULT 0,
    gaeste          INTEGER DEFAULT 0,
    extras          REAL DEFAULT 0,
    notizen         TEXT DEFAULT ''
);

CREATE TABLE IF NOT EXISTS event_cocktails (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    event_id    INTEGER REFERENCES events(id) ON DELETE CASCADE,
    cocktail_id INTEGER REFERENCES cocktails(id),
    menge       INTEGER NOT NULL DEFAULT 0
);

CREATE TABLE IF NOT EXISTS event_kosten (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    event_id    INTEGER REFERENCES events(id) ON DELETE CASCADE,
    kategorie   TEXT NOT NULL DEFAULT 'Zutaten/Waren',
    beschreibung TEXT,
    betrag      REAL NOT NULL
);
""")
conn.commit()
conn.close()
