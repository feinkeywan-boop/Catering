def umsatz_event(event: dict) -> float:
typ = event[“abrechnung”]
if typ == “pauschale”:
return event[“pauschale”]
elif typ == “pro_person”:
return event[“preis_pro_kopf”] * event[“gaeste”]
else:  # kombi
return event[“pauschale”] + (event[“preis_pro_kopf”] * event[“gaeste”]) + event[“extras”]

def kosten_event(event_id: int) -> float:
conn = get_conn()
row = conn.execute(“SELECT COALESCE(SUM(betrag),0) FROM event_kosten WHERE event_id=?”, (event_id,)).fetchone()
conn.close()
return row[0]

def rohkosten_cocktail(cocktail_id: int) -> float:
“”“Materialkosten eines Cocktails anhand seiner Rezeptur.”””
conn = get_conn()
rows = conn.execute(”””
SELECT z.kosten_pro_einheit * cz.menge
FROM cocktail_zutaten cz
JOIN zutaten z ON z.id = cz.zutaten_id
WHERE cz.cocktail_id = ?
“””, (cocktail_id,)).fetchall()
conn.close()
return sum(r[0] for r in rows)

def deckungsbeitrag_cocktail(cocktail_id: int, verkaufspreis: float) -> float:
return verkaufspreis - rohkosten_cocktail(cocktail_id)

def alle_events_df() -> pd.DataFrame:
conn = get_conn()
df = pd.read_sql(“SELECT * FROM events ORDER BY datum DESC”, conn)
conn.close()
if df.empty:
return df
df[“umsatz”] = df.apply(umsatz_event, axis=1)
df[“kosten”] = df[“id”].apply(kosten_event)
df[“gewinn”] = df[“umsatz”] - df[“kosten”]
df[“marge_%”] = df.apply(lambda r: (r[“gewinn”] / r[“umsatz”] * 100) if r[“umsatz”] else 0, axis=1)
df[“datum”] = pd.to_datetime(df[“datum”])
df[“monat”] = df[“datum”].dt.to_period(“M”).astype(str)
df[“jahr”] = df[“datum”].dt.year
return df

