                data.append({"Cocktail": cname, "Verkaufspreis": cpreis,
                             "Rohkosten": roh, "DB": db,
                             "DB-Marge%": db/cpreis*100 if cpreis else 0})

            cdf = pd.DataFrame(data)
            fig3 = px.bar(cdf, x="Cocktail", y=["Rohkosten", "DB"],
                          color_discrete_sequence=["#f87171", "#4ade80"],
                          barmode="stack",
                          labels={"value": "€", "variable": ""})
            fig3.update_layout(paper_bgcolor="#0f0f0f", plot_bgcolor="#0f0f0f",
                               font_color="#f0ede8", margin=dict(l=0,r=0,t=10,b=0))
            st.plotly_chart(fig3, use_container_width=True)

